{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"files": {
		"ignore": [
			"node_modules",
			"dist",
			"packages/*/dist",
			"packages/web/.next",
			".piv-loop",
			"bun.lock",
			"adhd-ai.local.config.ts"
		]
	},
	"formatter": {
		"enabled": true
	},
